# =============================================================================
# finsight — Environment Variables (template)
#
# 1. Copy this file to .env in the same directory:    cp .env.example .env
# 2. Fill in real values for what you need at your current phase.
# 3. Never commit .env to git — it's in .gitignore.
#
# Keys with placeholder values (e.g. "your-key-here") can be left as-is during
# early phases. They're only required when the corresponding feature is active.
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=finsight
APP_ENV=development                  # development | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
APP_LOG_FORMAT=console               # console | json   (use json in production)


# -----------------------------------------------------------------------------
# FastAPI server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# -----------------------------------------------------------------------------
# LLM providers
# Add the keys for whichever providers you want to use. Multi-provider support
# lets us route different tasks to different models for cost/latency tradeoffs.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
COHERE_API_KEY=your-cohere-key-here
GROQ_API_KEY=                        # optional — for very fast inference
TOGETHER_API_KEY=                    # optional — for open-weight models


# -----------------------------------------------------------------------------
# Model selection (which provider/model is used for each role)
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic               # openai | anthropic | groq | ollama
LLM_MODEL=claude-sonnet-4-5
LLM_TEMPERATURE=0.0

EMBEDDING_PROVIDER=openai            # openai | cohere | local (BGE/Nomic)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

RERANKER_PROVIDER=cohere             # cohere | bge | mxbai
RERANKER_MODEL=rerank-english-v3.0


# -----------------------------------------------------------------------------
# Vector database — Qdrant
# Local dev runs Qdrant in Docker via docker-compose. For production,
# point QDRANT_URL at Qdrant Cloud and set QDRANT_API_KEY.
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                      # leave empty for local Docker
QDRANT_COLLECTION=finsight_chunks


# -----------------------------------------------------------------------------
# PostgreSQL — for conversation history, user sessions, eval results
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finsight
POSTGRES_USER=finsight
POSTGRES_PASSWORD=change-this-in-production
DATABASE_URL=postgresql+asyncpg://finsight:change-this-in-production@localhost:5432/finsight


# -----------------------------------------------------------------------------
# Redis — caching + rate limiting
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0


# -----------------------------------------------------------------------------
# Langfuse — LLM observability & tracing (Phase 4)
# Self-hosted via Docker, or use Langfuse Cloud free tier
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001


# -----------------------------------------------------------------------------
# SEC EDGAR — required for data ingestion (Phase 2)
# SEC requires every API user to identify themselves via User-Agent.
# Format: "Name email@example.com"
# Reference: https://www.sec.gov/os/accessing-edgar-data
# -----------------------------------------------------------------------------
SEC_EDGAR_USER_AGENT=Your Name your-email@example.com


# -----------------------------------------------------------------------------
# Frontend (Next.js, apps/web) — read by Next.js at build & runtime
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser; keep secrets out.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# Authentication (Phase 4)
# Used to sign JWTs for user sessions. Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
