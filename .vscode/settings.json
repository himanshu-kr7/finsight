{
  // ============================================================================
  // finsight — shared VS Code workspace settings
  // Committed to git so all contributors get consistent editor behavior.
  // ============================================================================

  // ---------- Editor ----------
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  // ---------- Python ----------
  "python.defaultInterpreterPath": "${workspaceFolder}/apps/api/.venv/bin/python",
  "python.terminal.activateEnvironment": false,
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.indexing": true,
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingTypeStubs": "none"
  },
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["apps/api/tests"],

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // ---------- TypeScript / Next.js (for apps/web later) ----------
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "on"
  },

  // ---------- File hygiene ----------
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/htmlcov": true,
    "**/.coverage": true,
    "**/*.egg-info": true,
    "**/dist": true,
    "**/.next": true,
    "**/node_modules": false
  },
  "search.exclude": {
    "**/.venv": true,
    "**/uv.lock": true,
    "**/pnpm-lock.yaml": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/__pycache__": true,
    "**/htmlcov": true
  },

  // ---------- Spell checker ----------
  "cSpell.words": [
    "anthropic",
    "asyncpg",
    "bge",
    "BoundLogger",
    "contextvars",
    "cohere",
    "docling",
    "fastapi",
    "finsight",
    "Groq",
    "httpx",
    "iso",
    "langfuse",
    "langgraph",
    "llamaparse",
    "lru",
    "millis",
    "mxbai",
    "mypy",
    "nomic",
    "ollama",
    "openai",
    "pnpm",
    "pyarrow",
    "pydantic",
    "pyproject",
    "pytest",
    "qdrant",
    "RAGAs",
    "redoc",
    "reranker",
    "rerankers",
    "ruff",
    "structlog",
    "uvicorn",
    "uvloop",
    "watchfiles"
  ],

  // ---------- GitLens ----------
  "gitlens.codeLens.enabled": false,
  "gitlens.currentLine.enabled": true,

  // ---------- Terminal ----------
  "terminal.integrated.scrollback": 10000
}
